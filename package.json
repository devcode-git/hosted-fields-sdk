{
  "name": "hosted-fields-sdk",
  "version": "1.2.8",
  "description": "Hosted fields sdk",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./esm": {
      "import": "./dist/esm/index.js"
    }
  },
  "scripts": {
    "test": "test",
    "eslint": "eslint src",
    "build": "rimraf dist && npm run eslint && npm run build:cjs && npm run build:esm && npm run uglify",
    "build:cjs": "babel src --out-dir dist --env-name cjs",
    "uglify": "recursive-uglifyjs dist",
    "build:esm": "babel src --out-dir dist/esm --extensions '.js' --env-name esm"
  },
  "devDependencies": {
    "@babel/cli": "^7.26.4",
    "@babel/core": "^7.26.7",
    "@babel/eslint-parser": "^7.26.5",
    "@babel/plugin-transform-runtime": "^7.25.9",
    "@babel/preset-env": "^7.26.7",
    "babel-plugin-rewire": "^1.2.0",
    "babelify": "^10.0.0",
    "browserify": "^17.0.0",
    "eslint": "^8.57.1",
    "jasmine-core": "^4.0.1",
    "ncp": "^2.0.0",
    "recursive-uglifyjs": "0.2.0",
    "rimraf": "^3.0.2",
    "watchify": "^4.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devcode-git/hosted-fields-sdk.git"
  },
  "keywords": [
    "UI",
    "Payments",
    "Bambora",
    "Devcode"
  ],
  "author": "simon.solders@bambora.com",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/devcode-git/hosted-fields-sdk/issues"
  },
  "homepage": "https://github.com/devcode-git/hosted-fields-sdk#readme",
  "dependencies": {
    "@babel/runtime": "^7.27.0"
  }
}
