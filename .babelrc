{
    "plugins": [
        "@babel/plugin-transform-runtime",
        "rewire"
    ],
    "env": {
        "cjs": {
            "presets": [
                ["@babel/preset-env", { "modules": "commonjs" }]
            ]
        },
        "esm": {
            "presets": [
                ["@babel/preset-env", { "modules": false }]
            ]
        }
    }
}